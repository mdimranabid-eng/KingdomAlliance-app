rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || request.auth.token.email == 'md.imranabid@gmail.com');
    }

    function isApproved() {
      // Use get() to check profile approval status for relational gates
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('name', '') is string && data.get('name', '').size() <= 128) &&
             (data.get('profileType', 'bride') in ['bride', 'groom']) &&
             (data.get('aboutMe', '') is string && data.get('aboutMe', '').size() <= 2000) &&
             (data.get('denomination', '') is string && data.get('denomination', '').size() <= 100) &&
             (data.get('church', '') is string && data.get('church', '').size() <= 200) &&
             (data.get('education', '') is string && data.get('education', '').size() <= 200) &&
             (data.get('profession', '') is string && data.get('profession', '').size() <= 200) &&
             (data.get('location', '') is string && data.get('location', '').size() <= 200) &&
             (data.get('mobileNumber', '') is string && data.get('mobileNumber', '').size() <= 20) &&
             (data.get('emailVerified', false) is bool) &&
             (data.get('familyDetails', '') is string && data.get('familyDetails', '').size() <= 2000) &&
             (data.get('photoUrl', '') is string && data.get('photoUrl', '').size() <= 1000000) &&
             (data.get('pendingPhotoUrl', '') is string && data.get('pendingPhotoUrl', '').size() <= 1000000) &&
             (data.get('photoStatus', 'idle') in ['idle', 'pending', 'approved', 'rejected']) &&
             (data.get('photoPrivacy', 'public') in ['public', 'accepted_only']) &&
             (data.get('photoRejectionReason', '') is string && data.get('photoRejectionReason', '').size() <= 500) &&
             (data.get('approvalStatus', 'incomplete') in ['incomplete', 'pending', 'approved', 'rejected']) &&
             (data.get('onboardingComplete', false) is bool) &&
             (data.get('age', 0) is int && data.get('age', 0) >= 18 && data.get('age', 0) <= 100) &&
             (data.get('height', 0) is int && data.get('height', 0) >= 0 && data.get('height', 0) <= 300) &&
             (data.get('gender', '') in ['', 'male', 'female']) &&
             (data.get('gallery', []) is list);
    }

    function isValidInterest(data) {
      return data.fromId == request.auth.uid &&
             isValidId(data.toId) &&
             data.status in ['pending', 'accepted', 'declined'] &&
             data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 5000 &&
             data.createdAt == request.time &&
             (data.get('read', false) is bool) &&
             (data.get('receiverId', '') is string);
    }

    function isValidShortlist(data) {
      return data.userId == request.auth.uid &&
             isValidId(data.targetId) &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    // Collection Group for unread counts
    match /{path=**}/messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.receiverId == request.auth.uid || resource.data.senderId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.receiverId == request.auth.uid || isAdmin()) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /users/{userId} {
      allow get: if isValidId(userId) && isSignedIn() && (
        isOwner(userId) || 
        isAdmin() || 
        (isApproved() && existing().isApproved == true)
      );
      
      allow list: if isSignedIn() && (isAdmin() || isApproved());

      allow create: if isValidId(userId) && isOwner(userId) && incoming().uid == userId && incoming().email is string && incoming().createdAt == request.time;

      allow update: if isValidId(userId) && isSignedIn() && isValidUser(incoming()) && (
        // Owner Update
        (isOwner(userId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'mobileNumber', 'emailVerified', 'photoUrl', 'pendingPhotoUrl', 'photoStatus', 'gallery', 'aboutMe', 'denomination', 'church', 'education', 'profession', 'height', 'location', 'familyDetails', 'partnerPreferences', 'gender', 'age', 'approvalStatus', 'onboardingComplete', 'updatedAt']) &&
         incoming().uid == existing().uid &&
         incoming().email == existing().email &&
         incoming().createdAt == existing().createdAt &&
         incoming().isApproved == existing().isApproved &&
         incoming().status == existing().status &&
         incoming().updatedAt == request.time
        ) ||
        // Admin Update
        (isAdmin() && 
         incoming().diff(existing()).affectedKeys().hasOnly(['isApproved', 'photoApproved', 'photoStatus', 'photoRejectionReason', 'photoUrl', 'pendingPhotoUrl', 'gallery', 'status', 'approvalStatus', 'updatedAt']) &&
         incoming().updatedAt == request.time
        )
      );
    }

    match /interests/{interestId} {
      allow read: if isValidId(interestId) && isSignedIn() && (
        isOwner(resource.data.fromId) || isOwner(resource.data.toId) || isAdmin()
      );
      
      allow create: if isValidId(interestId) && isSignedIn() && isValidInterest(incoming()) && 
                    isApproved() &&
                    exists(/databases/$(database)/documents/users/$(incoming().toId));

      allow update: if isValidId(interestId) && isSignedIn() && (
        // Recipient can change status (accept/decline)
        (isOwner(existing().toId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
         incoming().status in ['accepted', 'declined']
        ) ||
        isAdmin()
      );

      allow delete: if isValidId(interestId) && isSignedIn() && (isOwner(existing().fromId) || isAdmin());
    }

    match /shortlists/{shortlistId} {
      allow read: if isValidId(shortlistId) && isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isValidId(shortlistId) && isSignedIn() && isValidShortlist(incoming()) && isApproved();
      allow delete: if isValidId(shortlistId) && isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    match /chats/{chatId} {
      function isParticipant() {
        return request.auth.uid in chatId.split('_');
      }

      allow read, get, list: if isValidId(chatId) && isSignedIn() && (isParticipant() || isAdmin());
      
      match /messages/{messageId} {
        allow read, get, list: if isValidId(messageId) && isSignedIn() && (isParticipant() || isAdmin());
        
        allow create: if isValidId(messageId) && isSignedIn() && isParticipant() && 
                      isValidMessage(incoming()) &&
                      incoming().chatId == chatId;
      }
    }

    match /photoModeration/{docId} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isValidId(adminId) && isSignedIn() && (isOwner(adminId) || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == adminId && (request.auth.token.email in ['md.imranabid@gmail.com']);
    }
  }
}
